APP_NAME="Soamco Budget"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://soamco.lo

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
FEATURE_IMPORT_ENABLED=false

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=soamco_budget
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=soamco.lo
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=mailtrap
TRANSACTIONAL_MAIL_PROVIDER=mailtrap
MAIL_FROM_ADDRESS="noreply@soamco.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS="support@soamco.com"
MAIL_SUPPORT_NAME="${APP_NAME} Support"
MAIL_SENDER_DOMAIN=soamco.com

MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_EHLO_DOMAIN=soamco.lo

MAILTRAP_SCHEME=tls
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
MAILTRAP_TIMEOUT=null
MAILTRAP_EHLO_DOMAIN=soamco.lo

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_SESSION_TOKEN=
AWS_SES_ENDPOINT=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

BREVO_SMTP_SCHEME=tls
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
BREVO_SMTP_TIMEOUT=null
BREVO_SMTP_EHLO_DOMAIN=soamco.com

TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

VITE_APP_NAME="${APP_NAME}"
REVERB_APP_ID=840001
REVERB_APP_KEY=soamcobudgetlocalkey
REVERB_APP_SECRET=soamcobudgetlocalsecret
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=soamco.lo,localhost,127.0.0.1
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=soamco.lo
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

UMAMI_ENABLED=false
UMAMI_HOST_URL=http://localhost:3001
UMAMI_SCRIPT_URL="${UMAMI_HOST_URL}/script.js"
UMAMI_WEBSITE_ID=
UMAMI_DOMAINS=soamco.lo
UMAMI_ENVIRONMENT_TAG=local
UMAMI_RESPECT_DNT=true

UMAMI_CONTAINER_NAME=soamco-budget-umami
UMAMI_PORT=3001
UMAMI_APP_SECRET=
UMAMI_DB_CONTAINER_NAME=soamco-budget-umami-db
UMAMI_DB_PORT=5433
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_DB_HOST=umami-db
UMAMI_DB_SSL_MODE=disable

AUTOMATION_ALERTS_ENABLED=true
AUTOMATION_ALERTS_DEDUPE_TTL_MINUTES=1440
AUTOMATION_ALERTS_TELEGRAM_ENABLED=false
AUTOMATION_ALERTS_TELEGRAM_BOT_TOKEN=
AUTOMATION_ALERTS_TELEGRAM_CHAT_ID=
AUTOMATION_BACKUPS_DISK=local
AUTOMATION_FULL_BACKUP_ENABLED=true
AUTOMATION_FULL_BACKUP_DIRECTORY=backups/full
AUTOMATION_USER_BACKUP_ENABLED=true
AUTOMATION_USER_BACKUP_DIRECTORY=backups/users
AUTOMATION_BACKUP_RETENTION_ENABLED=true
AUTOMATION_FULL_BACKUP_RETENTION_ENABLED=true
AUTOMATION_FULL_BACKUP_RETENTION_DAYS=90
AUTOMATION_USER_BACKUP_RETENTION_ENABLED=true
AUTOMATION_USER_BACKUP_RETENTION_DAYS=90
AUTOMATION_RUNNING_STALE_AFTER_MINUTES=30

KOFI_WEBHOOK_VERIFICATION_TOKEN=

RECAPTCHA_V3_ENABLED=false
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=
RECAPTCHA_V3_SCORE_THRESHOLD=0.5
RECAPTCHA_V3_LOGIN_SCORE_THRESHOLD=0.5
RECAPTCHA_V3_REGISTER_SCORE_THRESHOLD=0.5
RECAPTCHA_V3_TIMEOUT=5
RECAPTCHA_V3_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
RECAPTCHA_V3_LOG_RESULTS=true
RECAPTCHA_V3_EXPECTED_HOSTNAMES=soamco.com,www.soamco.com,soamco.lo

FEATURE_PUSH_NOTIFICATIONS_ENABLED=false
FEATURE_PUSH_NOTIFICATIONS_PROFILE_ENABLED=false
FIREBASE_CREDENTIALS=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
